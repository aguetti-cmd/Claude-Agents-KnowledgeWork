{
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-auto-memory-write.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/write-episode.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-em-dash.sh"
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": false,
  "env": {
    "GOOGLE_API_KEY": "YOUR_KEY_HERE"
  }
}
